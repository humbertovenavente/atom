# ============================================
# AI Agent Builder — Variables de Entorno
# ============================================
# Copiar este archivo como .env y llenar con valores reales
# NUNCA commitear el archivo .env al repositorio

# Base de datos MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/agent-builder?retryWrites=true&w=majority

# Modelo de IA (configurar según API key asignada)
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# Alternativa: Anthropic
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=https://api.anthropic.com

# Configuración general
NODE_ENV=development
